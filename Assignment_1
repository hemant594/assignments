   "source": [
    "\n",
    "dict1={\"Name\":\"Mohit\",\n",
    "        \"class\":\"B.Tech\"}\n",
    "dict2={\"address\":\"Bhiwadi\",\n",
    "        \"age\":\"21\"}\n",
    "merge_dict={}\n",
    "for key1,key2 in zip(dict1,dict2):\n",
