    "Ans.5 groupby() groups data based on categorical columns and applies aggregation functions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8e22f7a6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Department\n",
      "Finance    45000.0\n",
      "HR         55000.0\n",
      "IT         55000.0\n",
      "Name: Salary, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "data = {\n",
    "    \"Employee\": [\"A\", \"B\", \"C\", \"D\", \"E\"],\n",
    "    \"Department\": [\"IT\", \"HR\", \"IT\", \"Finance\", \"HR\"],\n",
    "    \"Salary\": [50000, 40000, 60000, 45000, 70000]\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "avg_salary = df.groupby(\"Department\")[\"Salary\"].mean()\n",
    "print(avg_salary)\n"
   ]
  }
