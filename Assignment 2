   "source": [
    "Ans.1 Python list usuage is more compared to NumPy Array, as Python list stores references to objects, can store mixed types whereas Numpy Array stores elements in contiguous memory, usually stores same data type "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "4914c1a5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "List Multiplication: [5, 12, 21, 32]\n",
      "NumPy Multiplication: [ 5 12 21 32]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "list1 = [1, 2, 3, 4]\n",
    "list2 = [5, 6, 7, 8]\n",
    "\n",
    "list_result = [a * b for a, b in zip(list1, list2)]\n",
    "print(\"List Multiplication:\", list_result)\n",
    "\n",
    "arr1 = np.array([1, 2, 3, 4])\n",
    "arr2 = np.array([5, 6, 7, 8])\n",
    "\n",
    "array_result = arr1 * arr2\n",
    "print(\"NumPy Multiplication:\", array_result)\n"
   ]
  },
  {
   "cell_type": "markdown",
