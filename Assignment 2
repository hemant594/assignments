    "Ans.4 Boolean Indexing filters data using True/False conditions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d94ae84c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  Name  Age Department  Salary  Experience\n",
      "0    A   22         IT   50000           1\n",
      "2    C   21         IT   60000           2\n"
     ]
    }
   ],
   "source": [
    "data = {\n",
    "    \"Name\": [\"A\", \"B\", \"C\", \"D\", \"E\"],\n",
    "    \"Age\": [22, 25, 21, 23, 26],\n",
    "    \"Department\": [\"IT\", \"HR\", \"IT\", \"Finance\", \"HR\"],\n",
    "    \"Salary\": [50000, 40000, 60000, 45000, 70000],\n",
    "    \"Experience\": [1, 3, 2, 4, 5]\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "filtered = df[(df[\"Salary\"] > 45000) & (df[\"Department\"] == \"IT\")]\n",
    "print(filtered)\n"
   ]
  },
